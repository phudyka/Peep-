DATABASE_URL=postgresql://peep:peep_password@postgres:5432/peep_db
JWT_SECRET=supersecretjwtkey
GEMINI_API_KEY=your_gemini_api_key_here

# ─── Intelligence layer ───────────────────────────────────────────────────────
# Source du catalogue produits Sage :
#   mock → jeu fictif en mémoire (défaut, aucune dépendance externe)
#   csv  → import d'un export CSV Sage (POST /api/admin/sage/import-csv)
#   api  → connexion REST à l'API Sage (renseigner SAGE_API_URL + SAGE_API_KEY)
SAGE_MODE=mock
SAGE_API_URL=
SAGE_API_KEY=
